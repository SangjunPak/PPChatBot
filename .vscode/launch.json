{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Streamlit App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "env": {
                "STREAMLIT_SERVER_RUN_ON_SAVE": "true"
            },
            "justMyCode": false,
            "args": [
                "run",
                "--server.port=8000"
            ]
        }
    ]
}